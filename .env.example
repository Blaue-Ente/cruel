# Cruel Mini App environment variables

# Required for ScraperAPI proxy (optional — set USE direct fetch by leaving empty)
SCRAPER_API_KEY=

# Hugging Face token for free LLM inference (optional — falls back to rule-based parser)
HF_TOKEN=
LLM_MODEL=HuggingFaceH4/zephyr-7b-beta

# Admin secret for API key management
ADMIN_SECRET=cruel-admin-change-me

APP_HOST=0.0.0.0
APP_PORT=8000
