# Cruel Mini App environment variables

# ScraperAPI proxy (optional)
SCRAPER_API_KEY=

# LLM provider: auto | nvidia | huggingface | rule
LLM_PROVIDER=auto

# NVIDIA NIM API — free models at https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Hugging Face Inference API (optional fallback)
HF_TOKEN=
HF_MODEL=HuggingFaceH4/zephyr-7b-beta

# Admin secret for API key management
ADMIN_SECRET=cruel-admin-change-me

APP_HOST=0.0.0.0
APP_PORT=8000
