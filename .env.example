# ArgosScout environment variables

SCRAPER_API_KEY=

# LLM: auto | groq | nvidia | huggingface | ollama | rule
LLM_PROVIDER=auto

# Groq — fastest free tier (console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# NVIDIA NIM (build.nvidia.com)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Hugging Face (fallback)
HF_TOKEN=
HF_MODEL=HuggingFaceH4/zephyr-7b-beta

# Ollama — local free SLM
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

ADMIN_SECRET=cruel-admin-change-me

# Vision scraping
VISION_ENABLED=true
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct

# Predictive pre-scraping
PREDICTIVE_ENABLED=true
PREDICTIVE_INTERVAL_SEC=300
PREDICTIVE_MAX_TOPICS=3

# Pheromones — Redis primary, SQLite fallback
REDIS_URL=redis://localhost:6379/0
PHEROMONE_BACKEND=auto

# IMAP inbox — real email responses from conversational probes
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
INBOX_ENABLED=false
INBOX_POLL_INTERVAL_SEC=120

# StockArgos ecosystem webhook
STOCKARGOS_WEBHOOK_URL=
STOCKARGOS_WEBHOOK_SECRET=

APP_HOST=0.0.0.0
APP_PORT=8000
